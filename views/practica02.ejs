<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">

    <title>practica 02</title>
</head>
<body class="container">


<%- include('partials/header.ejs') %>
<%- include('partials/nav.ejs') %>
<div class="container">
    <center>
        <h3>Cotizacion</h3>
    </center>

    <section class="formulario-container" style="padding: 20px;">
            <div id="formulario" class="container">
                <form action="/cotizacion" method="post" onsubmit="return validar()">
                    <div class="form-group">
                        <label for="valor">valor del automovil:</label>
                        <input type="number" name="valor" id="valor" value="<%-valor%>" required>
                    </div>


                    <div class="form-group">
                        <label for="pinicial"> porcentaje de pago inicial:</label>
                        <input type="number" name="pinicial" id="pinicial" value="<%-pinicial%>" required>
                    </div>


                    <div class="form-group">
                        <label for="plazos"></label>
                        <select name="plazos" id="plazos">

                            <option value="12" <%= plazos === 12 ? 'selected':'' %>>12 Meses</option>
                            <option value="24" <%= plazos === 24 ? 'selected':'' %>>24 Meses</option>
                            <option value="36" <%= plazos === 36 ? 'selected':'' %>>36 Meses</option>
                            <option value="48" <%= plazos === 48 ? 'selected':'' %>>48 Meses</option>
                            <option value="60" <%= plazos === 60 ? 'selected':'' %>>60 Meses</option>

                        </select>
                    </div>

                    <div class="buttons" style="margin: 20px 0px;">
                        <button type="submit" class="btn btn-primary">Enviar</button>
                        <a href="/cotizacion" class="btn btn-secondary">Limpiar</a>
                    </div>
                  

                </form>

                <section class="container">
                    <center>
                        <hr>
                        <h2>Resultados:</h2>
                        <hr>
                    </center>
                    
                    <% if (valor) { %>
                    <div class="card mt-4" style="max-width: 600px; margin: 0 auto;">
                        <div class="card-header bg-primary text-white">
                            <h4 class="mb-0 text-center">📄 Cotización de Financiamiento</h4>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-6"><strong>Fecha:</strong></div>
                                <div class="col-6 text-end"><%= new Date().toLocaleDateString('es-MX') %></div>
                            </div>
                            <hr>
                            <div class="row mb-3">
                                <div class="col-6"><strong>Valor del Automóvil:</strong></div>
                                <div class="col-6 text-end">$<%= Number(valor).toFixed(2) %></div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-6"><strong>Pago Inicial (<%= pinicial %>%):</strong></div>
                                <div class="col-6 text-end">$<%= (Number(valor) * Number(pinicial) / 100).toFixed(2) %></div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-6"><strong>Total a Financiar:</strong></div>
                                <div class="col-6 text-end">$<%= (Number(valor) - (Number(valor) * Number(pinicial) / 100)).toFixed(2) %></div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-6"><strong>Plazo:</strong></div>
                                <div class="col-6 text-end"><%= plazos %> Meses</div>
                            </div>
                            <hr>
                            <div class="row bg-light p-3 rounded">
                                <div class="col-6"><strong><h4>Pago Mensual:</h4></strong></div>
                                <div class="col-6 text-end"><h4 class="text-success">$<%= ((Number(valor) - (Number(valor) * Number(pinicial) / 100)) / Number(plazos)).toFixed(2) %></h4></div>
                            </div>
                        </div>
                        <div class="card-footer text-center text-muted">
                            <small>Cotización válida por 30 días</small>
                        </div>
                    </div>
                    <% } %>
                </section>

            </div>

    </section>

</div>
<%- include('partials/footer.ejs') %>
</body>
</html>